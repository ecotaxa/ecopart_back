{
  "name": "ecopart_back",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "test": "jest --watchAll --collectCoverage --collectCoverageFrom='src/**' --coveragePathIgnorePatterns '/test/' '/src/infra/' '/src/domain/entities/' '/src/domain/mocks/' ",
    "test-CI": "jest --collectCoverage  --collectCoverageFrom='src/**' --coveragePathIgnorePatterns '/test/' '/src/infra/' '/src/domain/entities/' '/src/domain/mocks/' ",
    "prepare": "npm run hooks:install",
    "clean": "rimraf ./dist",
    "hooks:install": "git config core.hooksPath .githooks",
    "copy-assets": "ts-node tools/copyAssets",
    "tsc": "tsc",
    "prod:build": " rimraf ./dist && tsc && ts-node tools/copyAssets",
    "prod:serve": "node dist/main.js",
    "prod:start": "npm run prod:build && node dist/main.js",
    "dev:build": "npm-run-all clean tsc copy-assets",
    "dev:serve": "nodemon -e js -w dist dist/main.js",
    "dev:watch": "nodemon --watch './**/*.ts' --exec 'ts-node' src/main.ts",
    "migrate:create": "ts-node tools/migrate.ts create",
    "migrate:up": "ts-node tools/migrate.ts up",
    "migrate:down": "ts-node tools/migrate.ts down",
    "migrate:status": "ts-node tools/migrate.ts status",
    "openapi:generate": "ts-node tools/generateOpenApi.ts",
    "openapi:validate": "npx @apidevtools/swagger-cli validate openapi.json",
    "openapi:watch": "nodemon --watch 'src/presentation/routers' --watch 'src/presentation/openapi' -e 'ts,yaml' --exec 'ts-node tools/generateOpenApi.ts'"
  },
  "keywords": [],
  "author": "Julie Coustenoble",
  "license": "LGPL-3.0-only",
  "dependencies": {
    "@types/csv-parse": "^1.2.5",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.6",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "fs": "^0.0.1-security",
    "i18n-iso-countries": "^7.7.0",
    "jsonwebtoken": "^9.0.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.5",
    "path": "^0.12.7",
    "sqlite3": "^6.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "yauzl": "^3.1.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@types/archiver": "^6.0.3",
    "@types/bcrypt": "^5.0.0",
    "@types/cookie-parser": "^1.4.3",
    "@types/express": "^4.17.17",
    "@types/fs-extra": "^9.0.13",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.3.3",
    "@types/nodemailer": "^6.4.13",
    "@types/shelljs": "^0.8.15",
    "@types/sqlite3": "^3.1.8",
    "@types/supertest": "^2.0.12",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yauzl": "^2.10.3",
    "@typescript-eslint/eslint-plugin": "^6.2.0",
    "@typescript-eslint/parser": "^6.2.0",
    "eslint": "^8.45.0",
    "fs-extra": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "rimraf": "^3.0.2",
    "shelljs": "^0.8.5",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2"
  }
}